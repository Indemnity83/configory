# Normalize text, keep repo LF
* text=auto eol=lf

# Common text file types
*.java  text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf

# Gradle wrapper
gradlew text eol=lf
gradlew.bat text eol=crlf

# Images/binaries
*.png binary
*.jpg binary
*.gif binary
*.jar binary
